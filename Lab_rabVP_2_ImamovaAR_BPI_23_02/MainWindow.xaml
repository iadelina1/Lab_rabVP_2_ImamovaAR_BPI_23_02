<Window x:Class="Lab_rabVP_2_ImamovaAR_BPI_23_02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторная работа №2 - ImamovaAR" Height="700" Width="500">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <UniformGrid Columns="2">
                <StackPanel Margin="5">
                    <TextBlock Text="Размер массива:"/>
                    <TextBox Text="{Binding ArraySize, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="25"/>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="Макс. потоков:"/>
                    <TextBox Text="{Binding MaxThreads, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="25"/>
                </StackPanel>
            </UniformGrid>
            <CheckBox Content="Использовать общий массив" IsChecked="{Binding UseSharedArray}" Margin="5"/>
            <UniformGrid Columns="3">
                <Button Content="Генерация" Command="{Binding GenerateArrayCommand}" Margin="5" Height="30"/>
                <Button Content="ПУСК ВСЕХ" Command="{Binding RunAllCommand}" Margin="5" Height="30" FontWeight="Bold" Background="LightGreen"/>
                <Button Content="Сброс" Command="{Binding ResetAllCommand}" Margin="5" Height="30"/>
            </UniformGrid>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding OriginalArrayString}" Foreground="Gray" Margin="5"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Bubble Sort" Margin="5">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="Пуск" Command="{Binding RunBubbleCommand}" Width="50" Margin="5"/>
                        <StackPanel>
                            <TextBlock Text="{Binding BubbleSortResult}"/>
                            <ProgressBar Value="{Binding BubbleProgress}" Height="10"/>
                        </StackPanel>
                    </DockPanel>
                </GroupBox>
                <GroupBox Header="Quick Sort" Margin="5">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="Пуск" Command="{Binding RunQuickCommand}" Width="50" Margin="5"/>
                        <StackPanel>
                            <TextBlock Text="{Binding QuickSortResult}"/>
                            <ProgressBar Value="{Binding QuickProgress}" Height="10"/>
                        </StackPanel>
                    </DockPanel>
                </GroupBox>
                <GroupBox Header="Insertion Sort" Margin="5">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="Пуск" Command="{Binding RunInsertionCommand}" Width="50" Margin="5"/>
                        <StackPanel>
                            <TextBlock Text="{Binding InsertionSortResult}"/>
                            <ProgressBar Value="{Binding InsertionProgress}" Height="10"/>
                        </StackPanel>
                    </DockPanel>
                </GroupBox>
                <GroupBox Header="Shaker Sort" Margin="5">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="Пуск" Command="{Binding RunShakerCommand}" Width="50" Margin="5"/>
                        <StackPanel>
                            <TextBlock Text="{Binding ShakerSortResult}"/>
                            <ProgressBar Value="{Binding ShakerProgress}" Height="10"/>
                        </StackPanel>
                    </DockPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3">
            <Button Content="ПРЕРВАТЬ ВСЕ" Command="{Binding CancelAllCommand}" Background="Tomato" Foreground="White" Margin="5" Height="35"/>
            <TextBlock Text="{Binding TotalComparisons}" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>