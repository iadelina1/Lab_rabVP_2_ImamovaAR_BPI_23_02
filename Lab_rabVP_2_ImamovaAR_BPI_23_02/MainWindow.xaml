<Window x:Class="Lab_rabVP_2_ImamovaAR_BPI_23_02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_rabVP_2_ImamovaAR_BPI_23_02"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Размер массива:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Width="100" VerticalAlignment="Center" 
                 Text="{Binding ArraySize, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
            <Button Content="Сгенерировать" Command="{Binding GenerateArrayCommand}" 
                Padding="15,5" Background="#E1E1E1"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#F9F9F9" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,0,15">
            <TextBlock Text="{Binding OriginalArrayString}" TextWrapping="Wrap" FontStyle="Italic" Foreground="#666666"/>
        </Border>

        <UniformGrid Grid.Row="2" Columns="1">
            <GroupBox Header="Сортировка пузырьком" Margin="0,5">
                <DockPanel LastChildFill="True" Margin="5">
                    <Button DockPanel.Dock="Right" Content="Пуск" Width="80" Height="30"
                        Command="{Binding BubbleSortCommand}"/>
                    <TextBlock Text="{Binding BubbleSortResult}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </DockPanel>
            </GroupBox>

            <GroupBox Header="Быстрая сортировка (QuickSort)" Margin="0,5">
                <DockPanel LastChildFill="True" Margin="5">
                    <Button DockPanel.Dock="Right" Content="Пуск" Width="80" Height="30"
                        Command="{Binding QuickSortCommand}"/>
                    <TextBlock Text="{Binding QuickSortResult}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </DockPanel>
            </GroupBox>

            <GroupBox Header="Сортировка вставками" Margin="0,5">
                <DockPanel LastChildFill="True" Margin="5">
                    <Button DockPanel.Dock="Right" Content="Пуск" Width="80" Height="30"
                        Command="{Binding InsertionSortCommand}"/>
                    <TextBlock Text="{Binding InsertionSortResult}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </DockPanel>
            </GroupBox>
        </UniformGrid>

        <Border Grid.Row="3" Background="#333" CornerRadius="5" Padding="10" Margin="0,10,0,0">
            <TextBlock Text="{Binding TotalComparisons}" Foreground="White" 
                   HorizontalAlignment="Center" FontSize="14" FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>
