<Window x:Class="Lab_rabVP_2_ImamovaAR_BPI_23_02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_rabVP_2_ImamovaAR_BPI_23_02"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Размер:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="80" Text="{Binding ArraySize, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

            <Button Content="Сгенерировать" 
            Command="{Binding GenerateArrayCommand}" 
            Margin="10,0,0,0" Padding="10,2"/>

            <Button Content="Сбросить всё" 
            Command="{Binding ResetAllCommand}" 
            Margin="5,0,0,0" Padding="10,2" 
            Background="#FFE5E5E5"/>
        </StackPanel>


        <TextBlock Grid.Row="1" Text="{Binding OriginalArrayString}" 
                   Foreground="Gray" 
                   Margin="0,0,0,10" 
                   TextWrapping="Wrap"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Пузырьковая сортировка" Margin="0,5">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding BubbleSortResult}" FontWeight="Bold"/>
                            <ProgressBar Value="{Binding BubbleProgress}" 
                                         Maximum="100" 
                                         Height="8" 
                                         Margin="0,5,10,0" 
                                         Foreground="#007ACC"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Content="Пуск" 
                                Command="{Binding BubbleSortCommand}" 
                                Width="60" 
                                Height="25"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Быстрая сортировка" Margin="0,5">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding QuickSortResult}" FontWeight="Bold"/>
                            <ProgressBar Value="{Binding QuickProgress}" Maximum="100" 
                                         Height="8" 
                                         Margin="0,5,10,0" 
                                         Foreground="#007ACC"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Content="Пуск" 
                                Command="{Binding QuickSortCommand}" 
                                Width="60" 
                                Height="25"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Сортировка вставками" Margin="0,5">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding InsertionSortResult}" FontWeight="Bold"/>
                            <ProgressBar Value="{Binding InsertionProgress}" 
                                         Maximum="100" 
                                         Height="8" 
                                         Margin="0,5,10,0" 
                                         Foreground="#007ACC"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Пуск" 
                                Command="{Binding InsertionSortCommand}" 
                                Width="60" 
                                Height="25"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Шейкерная сортировка" Margin="0,5">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding ShakerSortResult}" 
                                       FontWeight="Bold"/>
                            <ProgressBar Value="{Binding ShakerProgress}" 
                                         Maximum="100" 
                                         Height="8" 
                                         Margin="0,5,10,0" 
                                         Foreground="#007ACC"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Content="Пуск" 
                                Command="{Binding ShakerSortCommand}" 
                                Width="60" 
                                Height="25"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="3" Content="ПРЕРВАТЬ ВСЕ ПОТОКИ" 
            Command="{Binding CancelAllCommand}" 
            Background="#FFF07373" Foreground="White" FontWeight="Bold" 
            Padding="10" Margin="0,10"/>

        <Border Grid.Row="4" Background="#EEE" Padding="10" CornerRadius="3">
            <TextBlock Text="{Binding TotalComparisons}" HorizontalAlignment="Center" FontSize="14"/>
        </Border>
    </Grid>
</Window>
